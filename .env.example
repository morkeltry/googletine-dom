# AlgoMate agent payments (Tempo testnet) — real per-view micro-payments.
# Generate wallets + fund them with:  node scripts/setup-wallets.mjs
# Public addresses + chain config live in server/payments/wallets.json (committed).
# These SECRETS stay here (gitignored) locally, and in Coolify env in production.

# The agent's payer wallet — signs each per-view micro-payment. REQUIRED for real payments.
ALGOMATE_AGENT_KEY=
# Server-side signing secret for the MPP 402 challenges. REQUIRED. openssl rand -hex 32
MPP_SECRET_KEY=
# The seller wallet key — only needed to withdraw earnings later; the server never uses it.
ALGOMATE_SELLER_KEY=
# Price charged per video view, in pathUSD display units (optional; default 0.001).
ALGOMATE_PRICE_PER_VIEW=0.001

# GLM (Z.ai) — the agent's reasoning model (optional; falls back to a time rule without it).
ZAI_API_KEY=
GLM_MODEL=glm-5.2
