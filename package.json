{
  "name": "googletine",
  "version": "1.0.0",
  "description": "Payment-based proxy node for circumventing loginwalls",
  "main": "index.js",
  "type": "module",
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "mppx": "^0.7.0",
    "puppeteer": "^25.1.0",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "scripts": {
    "start-server": "node server/live-algo-server.js",
    "start-client": "node client/express/src/index.js",
    "watch-server": "nodemon --signal SIGHUP server/live-algo-server.js",
    "watch-client": "nodemon --signal SIGHUP client/express/src/index.js",
    "stop": "pkill -f 'server/live-algo-server.js' && pkill -f 'client/express/src/index.js'",
    "stop-server": "pkill -f 'server/live-algo-server.js'",
    "stop-client": "pkill -f 'client/express/src/index.js'",
    "persona": "node guil-cli.js",
    "test": "node test-cli.js",
    "test:cli": "node test-cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/morkeltry/googletine"
  },
  "author": "",
  "license": "ISC"
}
